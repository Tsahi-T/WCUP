# ===== בסיס נתונים משותף (Redis) =====
# ב-Vercel: Storage → Create Database → Upstash (Redis). האינטגרציה מזריקה
# אוטומטית את המשתנה REDIS_URL — לא צריך להגדיר כלום ידנית.
# הקוד מזהה גם KV_URL / UPSTASH_REDIS_URL / כל כתובת redis:// או rediss://.
#
# להרצה מקומית מול אותו מסד, העתיקו לכאן את כתובת החיבור:
REDIS_URL=

# מפתח TheSportsDB לשליפת תוצאות (ברירת מחדל: מפתח בדיקה ציבורי "3")
SPORTSDB_KEY=3
