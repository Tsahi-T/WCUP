# ===== בסיס נתונים משותף (Upstash Redis דרך Vercel) =====
# ב-Vercel: Storage → Create → Upstash Redis. המשתנים מוזרקים אוטומטית.
# להרצה מקומית מול ה-DD: העתיקו לכאן את הערכים.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# חלופה אם השתמשתם ב-Upstash ישירות (לא דרך Vercel):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# מפתח TheSportsDB לשליפת תוצאות (ברירת מחדל: מפתח בדיקה ציבורי "3")
SPORTSDB_KEY=3
